# .env example file for backend application
# default values set for local development

# App secrets
JWT_SECRET=change_this_to_a_secure_value!
NODE_ENV=development
PORT=4000
DEFAULT_RESERVATION_TTL_MS=900000

# Postgres (used by Prisma/TypeORM/etc)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=appdb

# Prisma / generic DATABASE_URL (use this pattern for Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/appdb?schema=public"

#SUPABASE
SUPABASE_POSTGRES_PASS=
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# Location
LOCATION_REQUEST_TTL_SECONDS=60
LOCATION_REQUEST_EXPIRY_SECONDS=60

# Lead Webhook secrets: add as needed
WEBHOOK_SECRET_DEFAULT=some-default-secret
WEBHOOK_SECRET_FACEBOOK=facebook-secret-from-app
WEBHOOK_SECRET_GOOGLE_FORMS=google-forms-secret-if-used

# Leads
LEAD_ASSIGN_MAX_ATTEMPTS=10
LEAD_ASSIGN_BASE_DELAY_MS=15000
LEAD_ASSIGN_MAX_DELAY_MS=600000
LEAD_ASSIGN_DEFAULT_STRATEGY=perSourceThenRoundRobin+capacity
LEAD_ASSIGN_WORKER_CONCURRENCY=4
DEFAULT_USER_MAX_OPEN=10
BULLMQ_PREFIX=lead-

# --- SOCKET & PUSH NOTIFICATIONS ---

# Firebase (FCM) - Get from Firebase Console > Service Accounts
# Option A: Paste the whole JSON string
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"project_id":"...","private_key":"...","client_email":"..."}'
# Option B: Path to the file
GOOGLE_APPLICATION_CREDENTIALS_PATH=./firebase-service-account.json

# WebPush (VAPID) - Generate via 'npx web-push generate-vapid-keys'
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Delivery Settings
# Expiry time for notifications in transit.
PUSH_DEFAULT_TTL_SECONDS=60