{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/modules/lead/assignment/worker/worker.ts",
    "start": "tsc && tsc-alias && node ./dist/index.js",
    "start:worker": "tsc && tsc-alias && node -r dotenv/config ./dist/src/modules/lead/assignment/worker/worker.js",
    "build": "tsc && tsc-alias",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.unit.config.ts",
    "test:integration": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.integration.config.ts --runInBand",
    "test:system": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.system.config.ts --runInBand",
    "test:watch": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config jest.unit.config.ts --watch",
    "migrate:test": "NODE_ENV=test prisma migrate deploy --schema=prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bull-board/api": "^6.14.2",
    "@bull-board/express": "^6.14.2",
    "@prisma/client": "^6.17.1",
    "@supabase/supabase-js": "^2.87.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.63.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "ioredis": "5.9.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@faker-js/faker": "^10.1.0",
    "@jest/globals": "^30.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/ioredis-mock": "^8.2.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.34.0",
    "fishery": "^2.4.0",
    "globals": "^16.3.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.2.0",
    "ngrok": "5.0.0-beta.2",
    "prisma": "^6.17.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-jest-resolver": "^2.0.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.40.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.9.3"
    }
  }
}
